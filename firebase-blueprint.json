{
  "entities": {
    "Persona": {
      "title": "Persona",
      "description": "Interviewee persona details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string", "enum": ["영업", "서비스"] },
        "description": { "type": "string" },
        "traits": { "type": "array", "items": { "type": "string" } },
        "mbti": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["상", "중", "하"] },
        "recentIssue": { "type": "string" }
      }
    },
    "Scenario": {
      "title": "Scenario",
      "description": "Interview scenario details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "guide": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "SimulationResult": {
      "title": "SimulationResult",
      "description": "Stores the results of an AI interview simulation session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The email or unique ID of the user." },
        "personaId": { "type": "string" },
        "scenarioId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "score": { "type": "number" },
        "grade": { "type": "string", "enum": ["S", "A", "B", "C", "D"] },
        "metrics": {
          "type": "object",
          "properties": {
            "trust": { "type": "number" },
            "acceptance": { "type": "number" },
            "stability": { "type": "number" },
            "engagement": { "type": "number" }
          }
        },
        "analysis": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "quantitative": {
              "type": "object",
              "properties": {
                "speechRatio": { "type": "number" },
                "safetyTrend": { "type": "array", "items": { "type": "number" } },
                "keywords": { "type": "array", "items": { "type": "string" } }
              }
            },
            "psychologicalResponse": { "type": "string" },
            "leadershipDiagnosis": { "type": "string" },
            "teamMemberNeeds": { "type": "string" },
            "strengths": { "type": "string" },
            "improvements": { "type": "string" },
            "recommendedDialogue": { "type": "string" },
            "executionGuide": { "type": "string" },
            "riskManagement": { "type": "string" },
            "actionGuide": { "type": "string" }
          }
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "personaId", "scenarioId", "timestamp", "score"]
    }
  },
  "firestore": {
    "/2026_G4_Simulation/personas/items/{personaId}": {
      "schema": "Persona",
      "description": "Collection of personas."
    },
    "/2026_G4_Simulation/scenarios/items/{scenarioId}": {
      "schema": "Scenario",
      "description": "Collection of scenarios."
    },
    "/simulations/{simulationId}": {
      "schema": "SimulationResult",
      "description": "Collection of simulation results."
    }
  }
}

