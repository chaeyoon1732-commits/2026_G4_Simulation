rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && (request.auth.token.email == userId || request.auth.uid == userId);
    }

    // 2026_G4_Simulation 컬렉션 규칙 (공백 제거)
    match /2026_G4_Simulation/{document=**} {
      allow read: if true; // 모든 사용자 읽기 허용 (페르소나/시나리오 정보)
      allow write: if isAuthenticated(); // 인증된 사용자만 쓰기 허용 (시딩 등)
    }

    match /simulations/{simulationId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.token.email || resource.data.userId == request.auth.uid);
    }
  }
}
